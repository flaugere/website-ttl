---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import HeroIlust from "../../assets/pics/tom_david_baudille_carre.jpg";
---

<Section id="home">
<div class="relative flex flex-col-reverse items-center md:flex-row" id="hero">
    <div class="row items-center py-5 md:w-6/12 md:pb-20 md:pt-10">
        <div class="text-left space-y-3">
            <h1 class="text-4xl font-medium leading-none md:text-6xl text-center md:text-left">Réalise ton <br />check-up Ultra Trail</h1>
            <p class="mt-6 mb-8 text-lg font-normal leading-7 sm:mb-12 text-center md:text-left md:pr-12">
                <strong>Prépare ton prochain Ultra Trail</strong> avec un check-up de notre équipe !<br />
                Tu veux <strong>faire le point sur ta préparation</strong>, identifier tes forces, préparer le renforcement et tes marges de progression avant ton objectif ?<br />
                Tu es juste curieux·se de savoir où tu en es ?<br />
            </p>
            <div class="w-full justify-center md:justify-start items-center inline-flex">
                <a href="#form" target="_blank" class="px-8 py-5 bg-orange hover:bg-white rounded-2xl text-center text-white hover:text-orange hover:text-orange border text-xl font-normal leading-7">
                    C'est parti !
                </a>
            </div>
        </div>
    </div>
    <div class="flex items-center py-5 md:w-6/12 md:pb-10 md:pt-10">
        <Image src={HeroIlust} alt="Hero Ilustration" loading="eager" class="rounded-[45px]"/>
    </div>
</div>
</Section>